{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ROS2 workspace",
            "type": "shell",
            "command": "source /opt/ros/jazzy/setup.bash && colcon build --symlink-install",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-l"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
